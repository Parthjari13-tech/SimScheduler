<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SIM Scheduler"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-manage your SIM cards on a schedule"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Permissions Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PERMISSIONS"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/accessibilityStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Checking..."
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/enableAccessibilityBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Enable Accessibility Service"
                    android:backgroundTint="@color/accent"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/alarmPermissionStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Checking alarm permission..."
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/grantAlarmPermissionBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Grant Alarm Permission"
                    android:backgroundTint="@color/accent"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SIM 1 Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/sim1Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- SIM 1 Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:text="1"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:gravity="center"
                                android:background="@drawable/sim_badge"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/sim1Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SIM 1"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/sim1Number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />

                        <!-- Shows the exact name used for matching -->
                        <TextView
                            android:id="@+id/sim1ActualName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="11sp"
                            android:textColor="@color/green"
                            android:layout_marginTop="2dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/sim1ScheduleToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Schedule"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- SIM 1 Time Pickers -->
                <LinearLayout
                    android:id="@+id/sim1ScheduleContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="8dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Turn OFF at" android:textSize="13sp"
                        android:textColor="@color/text_secondary" android:layout_marginBottom="4dp" />

                    <TimePicker android:id="@+id/sim1OffTimePicker"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:timePickerMode="spinner" android:layout_marginBottom="12dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="12dp" />

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Turn ON at" android:textSize="13sp"
                        android:textColor="@color/text_secondary" android:layout_marginBottom="4dp" />

                    <TimePicker android:id="@+id/sim1OnTimePicker"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:timePickerMode="spinner" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SIM 2 Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/sim2Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- SIM 2 Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:text="2"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:gravity="center"
                                android:background="@drawable/sim_badge_2"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/sim2Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SIM 2"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/sim2Number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />

                        <!-- Shows exact name used for matching -->
                        <TextView
                            android:id="@+id/sim2ActualName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="11sp"
                            android:textColor="@color/green"
                            android:layout_marginTop="2dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/sim2ScheduleToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Schedule"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- SIM 2 Time Pickers -->
                <LinearLayout
                    android:id="@+id/sim2ScheduleContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="8dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Turn OFF at" android:textSize="13sp"
                        android:textColor="@color/text_secondary" android:layout_marginBottom="4dp" />

                    <TimePicker android:id="@+id/sim2OffTimePicker"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:timePickerMode="spinner" android:layout_marginBottom="12dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="12dp" />

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Turn ON at" android:textSize="13sp"
                        android:textColor="@color/text_secondary" android:layout_marginBottom="4dp" />

                    <TimePicker android:id="@+id/sim2OnTimePicker"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:timePickerMode="spinner" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/nextActionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/refreshSimBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="🔄 Refresh SIM Detection"
            android:textSize="14sp"
            android:backgroundTint="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Schedules"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/accent"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
